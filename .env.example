STORAGE_BACKEND=r2              # "r2" or "minio"

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# MinIO (used if STORAGE_BACKEND=minio)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=personalcloud

# Database (Neon PostgreSQL with pgvector)
DATABASE_URL=

# General
WATCH_FOLDER=~/Documents
SUPPORTED_EXTENSIONS=.pdf,.docx,.txt,.md,.png,.jpg,.jpeg,.xlsx,.csv
EXCLUDE_PATHS=node_modules,.venv,venv,__pycache__,.git,dist,build,.next,.egg-info,*.LICENSE.txt

# API
API_HOST=127.0.0.1
API_PORT=8000
